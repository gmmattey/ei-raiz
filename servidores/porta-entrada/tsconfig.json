{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022"],
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "baseUrl": "../../",
    "paths": {
      "@ei/contratos": ["bibliotecas/contratos/src/index.ts"],
      "@ei/validacao": ["bibliotecas/validacao/src/index.ts"],
      "@ei/servico-autenticacao": ["servidores/modulos-backend/autenticacao/src/index.ts"],
      "@ei/servico-carteira": ["servidores/modulos-backend/carteira/src/index.ts"],
      "@ei/servico-decisoes": ["servidores/modulos-backend/decisoes/src/index.ts"],
      "@ei/servico-historico": ["servidores/modulos-backend/historico/src/index.ts"],
      "@ei/servico-importacao": ["servidores/modulos-backend/importacao/src/index.ts"],
      "@ei/servico-insights": ["servidores/modulos-backend/insights/src/index.ts"],
      "@ei/servico-perfil": ["servidores/modulos-backend/perfil/src/index.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "testes"]
}
