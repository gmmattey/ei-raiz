{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "types": [
      "@cloudflare/workers-types",
      "node"
    ],
    "noEmit": true
  },
  "include": [
    "src/**/*.ts",
    "testes/**/*.ts"
  ]
}
